# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Database files
*.db
*.db-shm
*.db-wal

# Android signing files (keep keystore safe!)
/gen/android/app/keystore.properties
/gen/android/app/*.keystore
/gen/android/app/build/outputs/apk/*.apk
